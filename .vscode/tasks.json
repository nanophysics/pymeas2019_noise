{
    // See https://go.microsoft.com/fwlink/?LinkId=733558
    // for the documentation about the tasks.json format
    "version": "2.0.0",
    "tasks": [
        {
            "label": "qt compile resources",
            "type": "shell",
            "command": "${workspaceFolder}/src/pymeas2019_noise/pyside6-rcc.sh",
            "options": {
                "cwd": "${workspaceFolder}/src/pymeas2019_noise/"
            },
            "problemMatcher": [],
            "group": {
                "kind": "build",
                "isDefault": true
            }
        },
        {
            "label": "qt designer",
            "type": "shell",
            "command": "${workspaceFolder}/src/pymeas2019_noise/pyside6-designer.sh",
            "options": {
                "cwd": "${workspaceFolder}/src/pymeas2019_noise/"
            },
            "problemMatcher": [],
            "group": {
                "kind": "build",
                "isDefault": true
            }
        },
        {
            "label": "pip upgrade",
            "type": "shell",
            "command": "uv pip install --no-deps --no-cache --upgrade -e .",
            "problemMatcher": []
        },
        {
            "label": "static check",
            "type": "shell",
            "command": "echo DONE",
            "problemMatcher": [],
            "dependsOn": [
                "ruff",
                "mypy",
                "pylint",
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            }
        },
        {
            "label": "ruff",
            "type": "shell",
            "command": ". .venv/bin/activate && ruff format --config pyproject.toml && ruff check --config pyproject.toml --fix || true",
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "problemMatcher": [],
            "group": {
                "kind": "build",
                "isDefault": false
            }
        },
        {
            "label": "mypy",
            "type": "shell",
            "command": ". .venv/bin/activate && python -m mypy --config-file pyproject.toml src tests || true",
            "options": {
                "cwd": "${workspaceFolder}",
                "env": {
                    "PYTHONPATH": "${workspaceFolder}"
                }
            },
            "problemMatcher": [],
            "group": {
                "kind": "build",
                "isDefault": false
            }
        },
        {
            "label": "pylint",
            "type": "shell",
            "command": ". .venv/bin/activate && PYTHONPATH=${workspaceFolder} python -m pylint src tests || true",
            "options": {
                "cwd": "${workspaceFolder}",
                "env": {
                    "PYTHONPATH": "${workspaceFolder}"
                }
            },
            "problemMatcher": [],
            "group": {
                "kind": "build",
                "isDefault": false
            }
        },
    ]
}